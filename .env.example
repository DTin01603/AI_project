# =========================
# Core model/search secrets
# =========================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# =========================
# Core app behavior
# =========================
RESEARCH_AGENT_ENABLED=true
DEFAULT_MAX_OUTPUT_TOKENS=1200

# =========================
# Advanced agent toggles
# =========================
ADVANCED_AGENT_ENABLED=true
ADVANCED_REFLECTION_ENABLED=true
ADVANCED_PLANNER_ENABLED=true
ADVANCED_CODE_EXECUTION_ENABLED=false
ADVANCED_MEMORY_ENABLED=true
ADVANCED_TOOL_REGISTRY_ENABLED=true
ADVANCED_MONITORING_ENABLED=true
ADVANCED_ALERTS_ENABLED=true

# =========================
# Advanced thresholds/limits
# =========================
ADVANCED_REFLECTION_THRESHOLD=70
ADVANCED_MAX_RETRIES=3
ADVANCED_CODE_TIMEOUT_SECONDS=30
ADVANCED_CODE_MEMORY_MB=512
ADVANCED_STREAM_BUFFER_SIZE=100
ADVANCED_MEMORY_RELEVANCE_THRESHOLD=0.6
ADVANCED_MEMORY_RETRIEVAL_LIMIT=10
ADVANCED_MEMORY_SUMMARY_TOKENS=10000
ADVANCED_TOOL_TIMEOUT_SECONDS=60
ADVANCED_TOOL_FAILURE_THRESHOLD=10
ADVANCED_TOOL_RATE_LIMIT_PER_MINUTE=100
ADVANCED_CODE_TIMEOUT_ALERT_THRESHOLD=0.1
ADVANCED_STREAM_FAILURE_ALERT_THRESHOLD=0.05

# =========================
# Shared dependencies
# =========================
ADVANCED_REDIS_ENABLED=true
ADVANCED_REDIS_URL=redis://redis:6379/0
ADVANCED_VECTOR_DB_ENABLED=false
ADVANCED_VECTOR_DB_BACKEND=inmemory
ADVANCED_VECTOR_DB_URL=

# Optional: Fernet key for memory encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ADVANCED_MEMORY_ENCRYPTION_KEY=

# Frontend
VITE_PROXY_TARGET=http://backend:8000
