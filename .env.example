# =========================
# Core model/search secrets
# =========================
# Use only ONE key to avoid SDK warning (prefer GEMINI_API_KEY)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GOOGLE_API_KEY=
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Google Custom Search (used by Research Tool)
GOOGLE_SEARCH_API_KEY=YOUR_GOOGLE_SEARCH_API_KEY
GOOGLE_SEARCH_ENGINE_ID=YOUR_GOOGLE_SEARCH_ENGINE_ID

# Optional external search provider key
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# =========================
# Core app behavior
# =========================
RESEARCH_AGENT_ENABLED=true
DEFAULT_MAX_OUTPUT_TOKENS=1200
DEFAULT_MODEL=gemini/gemini-2.5-flash
# DEFAULT_MODEL=groq/llama-3.3-70b-versatile

# =========================
# Research agent runtime (Phase 1/2/4/5/6)
# =========================
DATABASE_PATH=./data/conversations.db
ANALYSIS_TIMEOUT_SECONDS=2
LLM_TIMEOUT_SECONDS=10
PLANNING_TIMEOUT_SECONDS=5
RESEARCH_TIMEOUT_SECONDS=10
AGGREGATOR_TIMEOUT_SECONDS=3
RESPONSE_TIMEOUT_SECONDS=15
MAX_RESEARCH_TASKS=5
MAX_SEARCH_RESULTS=3
LOG_LEVEL=INFO

# LangGraph runtime
LANGGRAPH_CHECKPOINTER=sqlite
LANGGRAPH_DB_PATH=./checkpoints.db
# POSTGRES_CONNECTION_STRING=postgresql://user:pass@postgres:5432/research_agent

# Frontend
VITE_PROXY_TARGET=http://backend:8000

# LangSmith (optional, for advanced users)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2xxxxxxx
LANGSMITH_PROJECT="AI_project16"

# LangGraph Platform (optional when deploying with `langgraph up`)
# Keep this file as the deployment env source if you set `"env": ".env"` in langgraph.json.
# Logs written by Python `logging` will appear in Server logs view on Platform.

